---
// ContactCTA.astro — "Mulai Proyek Anda" form section, positioned above the footer
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const siteSettings = await reader.singletons.siteSettings.read();

const whatsapp = siteSettings?.whatsapp || '628123456789';
---

<section class="relative bg-[#1C1917] py-24 px-[6vw] overflow-hidden">
  
  <!-- Decorative architectural grid lines -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="cta-grid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M 80 0 L 0 0 0 80" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#cta-grid)" />
    </svg>
  </div>

  <!-- Corner accent marks -->
  <div class="absolute top-8 left-[6vw] w-12 h-12 border-l border-t border-stone-500/20"></div>
  <div class="absolute top-8 right-[6vw] w-12 h-12 border-r border-t border-stone-500/20"></div>
  <div class="absolute bottom-8 left-[6vw] w-12 h-12 border-l border-b border-stone-500/20"></div>
  <div class="absolute bottom-8 right-[6vw] w-12 h-12 border-r border-b border-stone-500/20"></div>

  <div class="max-w-4xl mx-auto relative z-10">
    
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="font-sans text-[10px] font-semibold tracking-[0.3em] text-stone-500 uppercase block mb-4">KONSULTASI GRATIS</span>
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-extralight text-stone-100 tracking-wide uppercase leading-tight">
        MULAI PROYEK<br/>
        <span class="italic font-normal text-stone-400">ANDA</span>
      </h2>
      <p class="font-sans text-sm text-stone-400 mt-6 max-w-lg mx-auto leading-relaxed">
        Konsultasikan proyek desain arsitektur, pembangunan baru, atau renovasi hunian Anda sekarang melalui WhatsApp.
      </p>
    </div>

    <!-- Form -->
    <form id="cta-contact-form" class="space-y-5 font-sans max-w-xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="cta-name" class="block text-[9px] font-semibold uppercase text-stone-400 mb-2 tracking-wider">Nama Lengkap</label>
          <input 
            type="text" 
            id="cta-name" 
            required 
            placeholder="Nama Anda" 
            class="w-full bg-transparent border border-stone-600/60 px-4 py-3.5 focus:outline-none focus:border-stone-400 text-stone-200 text-xs placeholder:text-stone-600 transition-colors duration-300"
          />
        </div>
        <div>
          <label for="cta-phone" class="block text-[9px] font-semibold uppercase text-stone-400 mb-2 tracking-wider">Nomor WhatsApp</label>
          <input 
            type="tel" 
            id="cta-phone" 
            required 
            placeholder="0812XXXXXXXX" 
            class="w-full bg-transparent border border-stone-600/60 px-4 py-3.5 focus:outline-none focus:border-stone-400 text-stone-200 text-xs placeholder:text-stone-600 transition-colors duration-300"
          />
        </div>
      </div>

      <div>
        <label for="cta-message" class="block text-[9px] font-semibold uppercase text-stone-400 mb-2 tracking-wider">Detail Permintaan</label>
        <textarea 
          id="cta-message" 
          rows="4" 
          required 
          placeholder="Contoh: Rencana pembangunan rumah 2 lantai, luas 200m², lokasi Jakarta Selatan..." 
          class="w-full bg-transparent border border-stone-600/60 px-4 py-3.5 focus:outline-none focus:border-stone-400 text-stone-200 text-xs placeholder:text-stone-600 resize-none transition-colors duration-300"
        ></textarea>
      </div>

      <button 
        type="submit" 
        class="w-full py-4 bg-stone-100 text-stone-900 hover:bg-stone-300 transition-all duration-300 font-semibold flex items-center justify-center gap-2.5 group cursor-pointer text-xs uppercase tracking-wider"
      >
        KIRIM PESAN VIA WHATSAPP
        <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </button>
    </form>

  </div>
</section>

<script is:inline define:vars={{ whatsappNumber: whatsapp }}>
  const ctaForm = document.getElementById('cta-contact-form');
  ctaForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = document.getElementById('cta-name').value;
    const phone = document.getElementById('cta-phone').value;
    const message = document.getElementById('cta-message').value;
    
    const formattedText = `Halo PT. DJC kontraktor, saya *${name}* (${phone}). Ingin berkonsultasi mengenai proyek: \n\n${message}`;
    const encodedText = encodeURIComponent(formattedText);
    const waUrl = `https://wa.me/${whatsappNumber}?text=${encodedText}`;
    
    window.open(waUrl, '_blank');
  });
</script>
