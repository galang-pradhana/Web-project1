---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const timData = await reader.singletons.timKami.read();

// Fallback values jika belum diisi di CMS
const headerEyebrow = timData?.headerEyebrow || 'STRUKTUR ORGANISASI';
const headerTitle = timData?.headerTitle || 'Keahlian Teknik & Visi Konstruksi';
const headerDescription = timData?.headerDescription || 'Di balik setiap proyek yang kokoh dan estetis, terdapat dedikasi dari para profesional berpengalaman yang mengutamakan keselamatan kerja, keterbukaan biaya, dan presisi di lapangan.';

const teamMembers = timData?.members || [];
---

<BaseLayout
  title="Tim Kami | PT. DJC kontraktor"
  description="Kenali tim ahli di balik kesuksesan proyek PT. DJC kontraktor. Para profesional berpengalaman dalam manajemen konstruksi, arsitektur, pengawasan lapangan, dan keselamatan kerja (K3)."
>
  <div class="pt-12 md:pt-16 pb-8 px-[6vw] max-w-7xl mx-auto space-y-8 md:space-y-12 text-text-primary relative overflow-hidden">
    
    <!-- Watermark Background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0 overflow-hidden">
      <span class="font-serif text-[15vw] font-black text-stone-200/10 uppercase tracking-wider select-none">
        OUR TEAM
      </span>
    </div>

    <!-- Page Header -->
    <div class="pb-6 relative z-10">
      <span class="font-sans text-[11px] font-semibold tracking-[0.2em] text-accent uppercase block mb-1.5">{headerEyebrow}</span>
      <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl font-normal text-text-primary leading-[1.1] mb-3">
        {headerTitle.includes('&') ? (
          <>{headerTitle.split('&')[0]}<span class="italic text-accent">&amp; {headerTitle.split('&')[1]?.trim()}</span></>
        ) : headerTitle}
      </h1>
      <p class="font-sans text-text-secondary text-sm md:text-base max-w-3xl leading-relaxed">
        {headerDescription}
      </p>
    </div>

    <!-- Featured Member Detail Area -->
    <section id="featured-detail" class="relative min-h-[180px] md:min-h-[380px] w-full z-10" aria-label="Detail Anggota Tim">
      {teamMembers.map((member, index) => (
        <div
          id={`detail-${member.id}`}
          class={`member-detail-pane group absolute inset-0 grid grid-cols-12 gap-4 md:gap-12 transition-opacity duration-500 ease-in-out ${index === 0 ? 'opacity-100 pointer-events-auto z-10' : 'opacity-0 pointer-events-none z-0'}`}
        >
          <!-- Foto Utama -->
          <div class="col-span-4 md:col-span-4 flex justify-center items-center overflow-hidden relative aspect-[3/4] max-h-[150px] md:max-h-[380px]">
            <img
              src={member.image}
              alt={`Foto profil ${member.name} - ${member.role}`}
              class="w-full h-full object-cover"
              loading={index === 0 ? "eager" : "lazy"}
            />
            <div class="absolute bottom-1.5 right-1.5 md:bottom-3 md:right-3 bg-stone-900/80 backdrop-blur-sm text-[8px] md:text-[9px] text-stone-100 px-1.5 py-0.5 md:px-2.5 md:py-1 tracking-widest font-sans uppercase rounded border border-stone-800/50 pointer-events-none select-none">
              Pilih Anggota &darr;
            </div>
          </div>

          <!-- Deskripsi Detail -->
          <div class="col-span-8 md:col-span-8 flex flex-col justify-center space-y-1 md:space-y-6 transition-all duration-700 ease-out transform translate-y-4 opacity-0 group-[.opacity-100]:translate-y-0 group-[.opacity-100]:opacity-100">
            <div>
              <span class="text-[9px] md:text-xs uppercase tracking-[0.2em] md:tracking-[0.25em] text-accent font-semibold block">{member.role}</span>
              <h2 class="font-serif text-sm sm:text-2xl md:text-4xl lg:text-5xl font-normal text-text-primary tracking-tight uppercase leading-none mt-0.5">
                {member.name}
              </h2>
            </div>
            <div class="h-[1px] bg-stone-300 w-12 md:w-24 my-1 md:my-0"></div>
            <p class="font-sans text-[11px] sm:text-sm md:text-base text-text-secondary leading-relaxed max-w-2xl line-clamp-4 md:line-clamp-none">
              {member.description}
            </p>
          </div>
        </div>
      ))}
    </section>

    <!-- Bottom Selection Row -->
    <section class="pt-6 md:pt-8 relative z-10" aria-label="Daftar Anggota Tim">

      <!-- Horizontal Scrollable Row / Desktop Grid -->
      <div 
        class="flex gap-3 md:gap-6 overflow-x-auto pb-4 scrollbar-hide snap-x snap-mandatory -mx-[6vw] px-[6vw] md:mx-0 md:px-0 md:grid items-end min-h-[160px] md:min-h-[300px]"
        style={`grid-template-columns: repeat(${teamMembers.length}, minmax(0, 1fr));`}
      >
        {teamMembers.map((member, index) => (
          <button
            data-member-id={member.id}
            class={`team-trigger snap-center group relative flex flex-col [&.active]:flex-col-reverse text-left focus:outline-none cursor-pointer w-[28vw] sm:w-[22vw] md:w-full flex-shrink-0 transition-all duration-500 p-2 md:p-3 border border-transparent bg-transparent rounded-lg [&.active]:bg-white [&.active]:shadow-[0_10px_30px_rgba(0,0,0,0.05)] [&.active]:-translate-y-2 md:[&.active]:-translate-y-4 z-10 [&.active]:z-20 ${index === 0 ? 'active' : ''}`}
            aria-label={`Lihat detail ${member.name}`}
            id={`trigger-${member.id}`}
          >
            <!-- Wadah Foto -->
            <div class="aspect-[3/4] w-full overflow-hidden bg-stone-100 transition-all duration-300">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover filter grayscale contrast-105 group-hover:grayscale-0 group-[.active]:grayscale-0 transition-all duration-500"
                loading="lazy"
              />
            </div>

            <!-- Info Nama & Peran -->
            <div class="mt-2 group-[.active]:mt-0 group-[.active]:mb-2 transition-all duration-300">
              <p class="font-serif text-[10px] md:text-sm font-bold text-text-primary uppercase leading-none truncate group-[.active]:text-accent transition-colors">{member.name}</p>
              <p class="font-sans text-[8px] md:text-[10px] text-text-secondary uppercase tracking-wider mt-1">{member.role}</p>
            </div>
          </button>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Sembunyikan scrollbar untuk kontainer snap horizontal */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.team-trigger');
    const panes = document.querySelectorAll('.member-detail-pane');

    let isAnimating = false;
    let activeClone = null;
    let activeTimeout = null;
    
    // Menyimpan elemen yang disembunyikan agar bisa dipulihkan jika ada interupsi
    let lastHiddenClickedImg = null;
    let lastHiddenTargetImg = null;

    function cleanUp() {
      if (activeClone) {
        activeClone.remove();
        activeClone = null;
      }
      if (lastHiddenClickedImg) {
        lastHiddenClickedImg.style.opacity = '1';
        lastHiddenClickedImg = null;
      }
      if (lastHiddenTargetImg) {
        lastHiddenTargetImg.style.opacity = '1';
        lastHiddenTargetImg.style.transition = '';
        lastHiddenTargetImg = null;
      }
      if (activeTimeout) {
        clearTimeout(activeTimeout);
        activeTimeout = null;
      }
      isAnimating = false;
    }

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-member-id');
        const currentActiveTrigger = document.querySelector('.team-trigger.active');

        if (currentActiveTrigger === trigger || isAnimating) return;

        // Bersihkan transisi sebelumnya jika ada interupsi
        cleanUp();

        const clickedImg = trigger.querySelector('img');
        const targetPane = document.getElementById(`detail-${targetId}`);
        if (!targetPane || !clickedImg) return;

        const targetFeaturedImg = targetPane.querySelector('img');
        if (!targetFeaturedImg) return;

        isAnimating = true;

        // 1. FIRST: Ukur bounding rect gambar di grid bawah
        const firstRect = clickedImg.getBoundingClientRect();

        // 2. TOGGLE CLASSES: Ubah kelas aktif pada trigger dan pane detail secara instan
        triggers.forEach(t => t.classList.remove('active'));
        trigger.classList.add('active');

        panes.forEach(pane => {
          if (pane.id === `detail-${targetId}`) {
            pane.classList.remove('opacity-0', 'pointer-events-none', 'z-0');
            pane.classList.add('opacity-100', 'pointer-events-auto', 'z-10');
          } else {
            pane.classList.remove('opacity-100', 'pointer-events-auto', 'z-10');
            pane.classList.add('opacity-0', 'pointer-events-none', 'z-0');
          }
        });

        // 3. LAST: Ukur bounding rect gambar utama atas yang baru saja diaktifkan di posisi akhirnya
        const lastRect = targetFeaturedImg.getBoundingClientRect();

        // 4. INVERT & PLAY: Buat klon gambar untuk animasi transisi melayang (FLIP)
        const clone = clickedImg.cloneNode(true) as HTMLImageElement;
        clone.style.position = 'fixed';
        clone.style.top = `${firstRect.top}px`;
        clone.style.left = `${firstRect.left}px`;
        clone.style.width = `${firstRect.width}px`;
        clone.style.height = `${firstRect.height}px`;
        clone.style.margin = '0';
        clone.style.zIndex = '9999';
        clone.style.pointerEvents = 'none';
        clone.style.transition = 'transform 1.0s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.0s ease-in-out';
        clone.style.transformOrigin = 'top left';
        clone.style.filter = 'none';
        clone.classList.remove('grayscale', 'group-hover:grayscale-0');

        document.body.appendChild(clone);
        activeClone = clone;

        // Force layout reflow to register initial styles
        clone.getBoundingClientRect();

        // Sembunyikan gambar asli sementara agar animasi klon terlihat menyatu
        clickedImg.style.opacity = '0';
        targetFeaturedImg.style.opacity = '0';
        targetFeaturedImg.style.transition = 'none';

        lastHiddenClickedImg = clickedImg;
        lastHiddenTargetImg = targetFeaturedImg;

        // Picu animasi meluncur ke posisi target akhir
        requestAnimationFrame(() => {
          const scaleX = lastRect.width / firstRect.width;
          const scaleY = lastRect.height / firstRect.height;
          const translateX = lastRect.left - firstRect.left;
          const translateY = lastRect.top - firstRect.top;

          clone.style.transform = `translate3d(${translateX}px, ${translateY}px, 0) scale(${scaleX}, ${scaleY})`;
        });

        // Akhiri animasi dan tampilkan gambar asli setelah durasi transisi selesai (1.0 detik = 1000ms)
        activeTimeout = setTimeout(() => {
          cleanUp();
        }, 1000);
      });
    });
  });
</script>
