---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { Compass, Calculator, Wrench, CheckCircle2 } from 'lucide-react';

const reader = createReader(process.cwd(), keystaticConfig);
const rawServices = await reader.collections.services.all();
const services = rawServices.map(s => ({
  slug: s.slug,
  ...s.entry
}));

const iconMap = {
  'Compass': Compass,
  'Calculator': Calculator,
  'Wrench': Wrench
};

const serviceFlows = [
  { step: '01', title: 'Konsultasi & Konsep Desain', desc: 'Diskusi awal mengenai visi hunian, kebutuhan ruang, estimasi anggaran (RAB awal), dan pembuatan konsep desain arsitektur 3D.' },
  { step: '02', title: 'Perencanaan Detail (DED)', desc: 'Penyusunan gambar kerja teknis (Detail Engineering Design), spesifikasi material final, serta perhitungan Rencana Anggaran Biaya yang presisi.' },
  { step: '03', title: 'Konstruksi & Pembangunan', desc: 'Pelaksanaan pembangunan fisik di lapangan oleh tim sipil ahli, dikawal oleh pengawasan berkala demi menjaga kesesuaian standar struktur & arsitektur.' },
  { step: '04', title: 'Serah Terima & Garansi', desc: 'Pemeriksaan akhir (checklist kualitas) bersama klien, serah terima kunci secara formal, serta pemberian garansi pemeliharaan struktur bangunan.' }
];
---

<BaseLayout 
  title="Jasa Kontraktor & Arsitektur Jabodetabek | PT. Dicko Jaya Construction"
  description="Layanan konstruksi sipil terlengkap: bangun baru, renovasi rumah, ruko, gedung komersial, gudang, serta desain arsitektur interior tropis modern."
>
  
  <div class="py-24 px-[6vw] max-w-7xl mx-auto space-y-32 relative">
    
    {/* Page Header */}
    <div class="border-b border-stone-300 pb-8 mb-12">
      <span class="font-sans text-[11px] font-semibold tracking-[0.2em] text-accent uppercase block mb-2">SPESIALISASI KAMI</span>
      <h1 class="font-serif text-4xl sm:text-5xl font-normal text-text-primary leading-[1.1] mb-4">
        LAYANAN <span class="italic text-accent">KONTRAKTOR & ARSITEKTUR</span>
      </h1>
      <p class="font-sans text-text-secondary text-[15px] sm:text-base max-w-3xl leading-relaxed">
        Dari gagasan arsitektural yang visioner hingga konstruksi fisik yang kokoh di lapangan. Kami menyediakan solusi satu atap yang mengedepankan kualitas estetika, transparansi biaya, dan kekuatan struktur.
      </p>
    </div>

    {/* Service Cards Detailed List */}
    <div class="space-y-12">
      {services.map((srv, idx) => {
        const IconComponent = iconMap[srv.icon] || Compass;
        const isEven = idx % 2 === 0;
        
        return (
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center border border-stone-200/80 p-8 bg-[#FAF9F6] relative transition-all duration-300 hover:border-accent/30">
            
            {/* Visual Panel */}
            <div class={`lg:col-span-5 ${isEven ? 'lg:order-first' : 'lg:order-last'} aspect-video w-full overflow-hidden bg-stone-100`}>
              {srv.coverImage ? (
                <img 
                  src={srv.coverImage} 
                  alt={srv.name} 
                  class="w-full h-full object-cover filter sepia-[0.1] hover:sepia-0 transition-all duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-accent">
                  <IconComponent class="w-12 h-12" />
                </div>
              )}
            </div>

            {/* Copy Panel */}
            <div class="lg:col-span-7 space-y-6">
              <div class="inline-flex items-center gap-2 border border-stone-200 px-3 py-1 bg-stone-50 font-sans text-[10px] font-medium uppercase tracking-widest text-accent">
                LAYANAN {idx + 1}
              </div>
              <h2 class="font-serif text-2xl sm:text-3xl font-normal text-text-primary">
                {srv.name}
              </h2>
              <p class="font-sans text-text-secondary text-[14px] sm:text-[15px] leading-relaxed">
                {srv.description}
              </p>
              
              <div class="pt-2 flex flex-wrap gap-x-6 gap-y-2 text-xs font-sans text-stone-600">
                <span class="flex items-center gap-1.5"><CheckCircle2 class="w-4 h-4 text-accent" /> Presisi Konstruksi</span>
                <span class="flex items-center gap-1.5"><CheckCircle2 class="w-4 h-4 text-accent" /> Desain Eksklusif</span>
                <span class="flex items-center gap-1.5"><CheckCircle2 class="w-4 h-4 text-accent" /> RAB Transparan & Terjamin</span>
              </div>
            </div>

          </div>
        );
      })}
    </div>

    {/* Workflow Flowchart */}
    <div class="space-y-16">
      <div class="border-b border-stone-300 pb-6">
        <span class="font-sans text-[11px] font-semibold tracking-[0.2em] text-accent uppercase block mb-2">ALUR KERJA</span>
        <h2 class="font-serif text-3xl font-normal text-text-primary">METODE KERJA PT. DICKO JAYA CONSTRUCTION</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {serviceFlows.map((flow) => (
          <div class="border border-stone-200/80 bg-[#FAF9F6] p-6 space-y-4 hover:border-accent/30 transition-all duration-300">
            <span class="block font-serif font-normal text-4xl text-accent/80">{flow.step}</span>
            <h3 class="font-serif text-lg font-normal text-text-primary border-b border-stone-200 pb-2">{flow.title}</h3>
            <p class="text-xs sm:text-sm text-text-secondary leading-relaxed font-sans">{flow.desc}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Payment Terms Section */}
    <div class="space-y-16 pt-8">
      <div class="border-b border-stone-300 pb-6">
        <span class="font-sans text-[11px] font-semibold tracking-[0.2em] text-accent uppercase block mb-2">SISTEM PEMBAYARAN</span>
        <h2 class="font-serif text-3xl font-normal text-text-primary">ALUR PEMBAYARAN YANG TRANSPARAN & ADIL</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-4 hover:border-accent/30 transition-all duration-300">
          <span class="block font-serif font-semibold text-5xl text-accent/80">40%</span>
          <h3 class="font-serif text-lg font-normal text-text-primary border-b border-stone-200 pb-2">Termin I (DP & Material)</h3>
          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed font-sans">
            Dibayarkan saat pekerja telah tiba di lokasi, material pertama sudah tersedia, dan pekerjaan fisik telah dimulai.
          </p>
        </div>
        
        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-4 hover:border-accent/30 transition-all duration-300">
          <span class="block font-serif font-semibold text-5xl text-accent/80">40%</span>
          <h3 class="font-serif text-lg font-normal text-text-primary border-b border-stone-200 pb-2">Termin II (Progres)</h3>
          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed font-sans">
            Dibayarkan sesuai dengan kesepakatan progres pekerjaan yang telah dicapai di lapangan secara berkala.
          </p>
        </div>

        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-4 hover:border-accent/30 transition-all duration-300">
          <span class="block font-serif font-semibold text-5xl text-accent/80">20%</span>
          <h3 class="font-serif text-lg font-normal text-text-primary border-b border-stone-200 pb-2">Termin III (Serah Terima)</h3>
          <p class="text-xs sm:text-sm text-text-secondary leading-relaxed font-sans">
            Dibayarkan setelah seluruh pekerjaan diselesaikan 100% sesuai dengan standar kualitas yang disepakati.
          </p>
        </div>
      </div>
    </div>

    {/* Unique Advantages Section */}
    <div class="space-y-16">
      <div class="border-b border-stone-300 pb-6">
        <span class="font-sans text-[11px] font-semibold tracking-[0.2em] text-accent uppercase block mb-2">KEUNGGULAN EKSKLUSIF</span>
        <h2 class="font-serif text-3xl font-normal text-text-primary">SOLUSI FLEKSIBEL & TRANSPARAN</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-3 hover:border-accent/30 transition-all duration-300 group">
          <div class="inline-flex items-center gap-2 text-accent font-sans text-xs font-semibold tracking-widest uppercase mb-2">
            <CheckCircle2 class="w-4 h-4" />
            GRATIS
          </div>
          <h3 class="font-serif text-xl font-normal text-text-primary">Free Survey & Free Design</h3>
          <p class="font-sans text-sm text-text-secondary leading-relaxed">
            Layanan survei lokasi dan konsultasi desain arsitektur secara GRATIS untuk wilayah Jabodetabek. Tim kami datang langsung ke lokasi untuk meninjau kebutuhan sebelum pengerjaan dimulai.
          </p>
        </div>

        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-3 hover:border-accent/30 transition-all duration-300 group">
          <div class="inline-flex items-center gap-2 text-accent font-sans text-xs font-semibold tracking-widest uppercase mb-2">
            <CheckCircle2 class="w-4 h-4" />
            TRANSPARAN
          </div>
          <h3 class="font-serif text-xl font-normal text-text-primary">RAB Mendetail Tanpa Biaya Tersembunyi</h3>
          <p class="font-sans text-sm text-text-secondary leading-relaxed">
            Setiap alokasi dana dalam Rencana Anggaran Biaya dijelaskan secara rinci dan transparan. Anda dapat memantau penggunaan anggaran secara penuh sejak awal proyek.
          </p>
        </div>

        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-3 hover:border-accent/30 transition-all duration-300 group">
          <div class="inline-flex items-center gap-2 text-accent font-sans text-xs font-semibold tracking-widest uppercase mb-2">
            <CheckCircle2 class="w-4 h-4" />
            TRANSPARAN
          </div>
          <h3 class="font-serif text-xl font-normal text-text-primary">Sistem Pembayaran 3 Termin</h3>
          <p class="font-sans text-sm text-text-secondary leading-relaxed">
            Kami menerapkan sistem pembayaran 3 Termin (40% - 40% - 20%) yang transparan dan adil untuk menjamin kelancaran proyek dan memberikan ketenangan bagi Anda di setiap tahapan progres.
          </p>
        </div>

        <div class="border border-stone-200/80 bg-[#FAF9F6] p-8 space-y-3 hover:border-accent/30 transition-all duration-300 group">
          <div class="inline-flex items-center gap-2 text-accent font-sans text-xs font-semibold tracking-widest uppercase mb-2">
            <CheckCircle2 class="w-4 h-4" />
            ADAPTIF
          </div>
          <h3 class="font-serif text-xl font-normal text-text-primary">Penyesuaian Budget Tanpa Kompromi Kualitas</h3>
          <p class="font-sans text-sm text-text-secondary leading-relaxed">
            Kami berkomitmen menyesuaikan rencana proyek dengan budget yang Anda miliki, sambil tetap menjaga standar material dan kualitas konstruksi terbaik. Harga menyesuaikan, kualitas terjaga.
          </p>
        </div>
      </div>
    </div>

    {/* K3 Safety Badge */}
    <div class="bg-stone-900 text-stone-100 p-10 md:p-14">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="space-y-4">
          <span class="font-sans text-[11px] font-semibold tracking-[0.2em] uppercase block" style="color: #C5A078;">STANDAR KESELAMATAN KERJA</span>
          <h2 class="font-serif text-3xl font-normal text-stone-100 leading-tight">
            K3 — KESELAMATAN & <span class="italic" style="color: #C5A078;">KESEHATAN KERJA</span>
          </h2>
          <p class="font-sans text-sm text-stone-400 leading-relaxed">
            Seluruh proyek PT. Dicko Jaya Construction dilaksanakan dengan prosedur K3 yang ketat — penggunaan APD standar SNI, identifikasi bahaya sebelum pekerjaan dimulai, serta pengawasan berkala selama masa konstruksi untuk memastikan keselamatan tim dan lingkungan sekitar.
          </p>
          <a href="/tentang" class="inline-flex items-center gap-2 font-sans text-xs font-semibold tracking-widest uppercase border-b pb-0.5 hover:text-stone-100 transition-colors duration-200 mt-2" style="color: #C5A078; border-color: #C5A078;">
            Pelajari Komitmen K3 Kami →
          </a>
        </div>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="border border-stone-700 p-5 space-y-2">
            <span class="font-serif text-3xl font-normal block" style="color: #C5A078;">APD</span>
            <span class="font-sans text-[10px] tracking-widest uppercase text-stone-400">Standar SNI</span>
          </div>
          <div class="border border-stone-700 p-5 space-y-2">
            <span class="font-serif text-3xl font-normal block" style="color: #C5A078;">HIRA</span>
            <span class="font-sans text-[10px] tracking-widest uppercase text-stone-400">Analisis Risiko</span>
          </div>
          <div class="border border-stone-700 p-5 space-y-2">
            <span class="font-serif text-3xl font-normal block" style="color: #C5A078;">100%</span>
            <span class="font-sans text-[10px] tracking-widest uppercase text-stone-400">Pengawasan</span>
          </div>
        </div>
      </div>
    </div>

  </div>

</BaseLayout>
