---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AlertTriangle, Home, ArrowLeft } from 'lucide-react';
---

<BaseLayout 
  title="Halaman Tidak Ditemukan — PT. Dicko Jaya Construction" 
  description="Maaf, halaman yang Anda cari tidak dapat ditemukan. Silakan kembali ke Beranda atau hubungi kami untuk informasi lebih lanjut."
>
  
  <div class="py-32 px-[6vw] max-w-7xl mx-auto min-h-[70vh] flex flex-col justify-center items-center text-center relative text-text-primary">
    
    {/* Animated Decorative Element */}
    <div class="mb-8 p-6 bg-accent/5 rounded-full border border-accent/10 animate-pulse">
      <AlertTriangle class="w-12 h-12 text-accent" />
    </div>

    {/* Title Section */}
    <div class="space-y-4 max-w-2xl mb-12">
      <span class="font-sans text-[11px] font-semibold tracking-[0.25em] text-accent uppercase block">ERROR CODE 404</span>
      
      <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl font-normal text-text-primary leading-none tracking-tight">
        HALAMAN <span class="italic text-accent">TIDAK DITEMUKAN</span>
      </h1>
      
      <p class="font-sans text-text-secondary text-[14px] sm:text-base leading-relaxed mt-6">
        Maaf, halaman yang Anda cari tidak dapat ditemukan, telah dihapus, atau sedang dalam pemeliharaan. Silakan kembali ke halaman utama atau jelajahi portofolio kami.
      </p>
    </div>

    {/* Navigation Links */}
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md">
      <a 
        href="/" 
        class="w-full sm:w-auto px-8 py-4 bg-stone-900 text-stone-100 hover:bg-accent hover:text-stone-100 transition-colors duration-300 font-sans text-xs font-semibold uppercase tracking-widest flex items-center justify-center gap-2 cursor-pointer shadow-sm"
      >
        <Home class="w-4 h-4" /> KEMBALI KE BERANDA
      </a>
      <a 
        href="/portofolio" 
        class="w-full sm:w-auto px-8 py-4 bg-transparent border border-stone-300 text-text-primary hover:border-stone-900 hover:bg-stone-50 transition-colors duration-300 font-sans text-xs font-semibold uppercase tracking-widest flex items-center justify-center gap-2 cursor-pointer"
      >
        JELAJAHI PORTOFOLIO <ArrowLeft class="w-4 h-4 rotate-180" />
      </a>
    </div>

  </div>

</BaseLayout>
