---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const rawProjects = await reader.collections.projects.all();
const projects = rawProjects.map(p => ({
  slug: p.slug,
  ...p.entry
})).filter(p => !p.isArchived);

// Variasi aspek rasio asimetris untuk estetika editorial premium (OH Architecture style)
const layouts = [
  { container: 'w-full aspect-[3/4] md:h-[58vh] md:aspect-[3/4]' },     // Tinggi Tegak (Vertikal)
  { container: 'w-full aspect-[16/10] md:h-[45vh] md:aspect-[16/10]' }, // Lebar Sedang (Horizontal)
  { container: 'w-full aspect-[1/1] md:h-[52vh] md:aspect-[1/1]' },     // Kotak (Square)
  { container: 'w-full aspect-[4/3] md:h-[38vh] md:aspect-[4/3]' }      // Kecil Lebar
];
---

<BaseLayout 
  title="Portofolio Kontraktor & Arsitektur — PT. Dicko Jaya Construction"
  description="Portofolio proyek konstruksi dan arsitektur PT. Dicko Jaya Construction — hunian minimalis, kontemporer, dan industrial di Bogor, Tangerang, dan Jabodetabek."
  heroFullBleed={true}
  hideFooter={true}
>
  <!-- Main Scroll Container (Horizontal on Desktop, Vertical on Mobile) -->
  <div class="horizontal-scroll-container w-full min-h-screen md:overflow-hidden bg-[#FAF9F6] relative flex flex-col md:flex-row md:items-center">
    
    <!-- Stuck Intro Section (Fixed on desktop, static/inline on mobile) -->
    <div class="stuck-intro md:absolute md:left-[8vw] md:top-1/2 md:-translate-y-1/2 md:w-[400px] w-full px-[8vw] pt-28 md:pt-0 pb-8 md:pb-0 z-10 flex flex-col justify-center md:pr-8 space-y-6 pointer-events-none">
      <span class="font-sans text-[10px] font-semibold tracking-[0.25em] text-accent uppercase block">PT. DICKO JAYA CONSTRUCTION</span>
      <h1 class="font-serif text-3xl md:text-5xl font-light text-stone-900 leading-tight">
        KURASI KARYA <br/><span class="italic text-accent font-normal">ARSITEKTUR & RAB</span>
      </h1>
      <p class="font-sans text-stone-500 text-xs md:text-sm leading-relaxed font-light">
        Kumpulan proyek pilihan pembangunan hunian mewah, gedung komersial, dan renovasi presisi tinggi yang memadukan kekuatan struktur dengan keindahan visual.
      </p>
    </div>
    
    <!-- Outer track (Slides horizontally on desktop, stacks vertically on mobile) -->
    <div class="horizontal-track flex flex-col md:flex-row items-center gap-16 md:gap-24 px-[8vw] py-12 md:py-0 h-auto md:h-full select-none w-full md:w-auto">
      
      <!-- Spacer for Intro Section (Desktop only) -->
      <div class="hidden md:block flex-shrink-0 w-[400px] mr-16"></div>

      <!-- Projects Slides with asymmetric layout structure -->
      {projects.map((proj, idx) => {
        const layout = layouts[idx % layouts.length];
        
        return (
          <div class="w-full md:w-auto flex-shrink-0 flex flex-col justify-center project-item">
            <a href={`/portofolio/${proj.slug}`} class="group block cursor-pointer">
              <!-- Image & Video element with premium transition styling -->
              <div class={`${layout.container} overflow-hidden bg-stone-100 relative`}>
                <img 
                  src={proj.coverImage} 
                  alt={proj.title}
                  class="w-full h-full object-cover filter brightness-[0.96] contrast-[1.02] sepia-[0.08] hover:sepia-0 hover:brightness-100 transition-all duration-1000 group-hover:scale-[1.03]"
                  loading="lazy"
                />
                {proj.coverVideo && (
                  <video
                    data-src={proj.coverVideo}
                    class="lazy-portfolio-video absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-1000 group-hover:scale-[1.03] pointer-events-none"
                    muted
                    loop
                    playsinline
                    preload="none"
                  />
                )}
                <!-- Subtle overlay shade -->
                <div class="absolute inset-0 bg-stone-900/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
              </div>
              
              <!-- Label / Metadata below image -->
              <div class="mt-4 space-y-1">
                <h3 class="font-sans text-xs md:text-sm font-semibold tracking-widest text-stone-900 uppercase group-hover:text-accent transition-colors duration-300">
                  {proj.title}
                </h3>
                <p class="font-sans text-[10px] text-stone-500 uppercase tracking-[0.2em] font-light">
                  {proj.category} — {proj.location}
                </p>
              </div>

            </a>
          </div>
        );
      })}

      <!-- Final Slide: CTA to Contact -->
      <div class="w-full md:w-[450px] flex-shrink-0 flex flex-col justify-center md:pl-8 space-y-6 pb-24 md:pb-0 pr-[8vw]">
        <span class="font-sans text-[10px] font-semibold tracking-[0.25em] text-accent uppercase block">KOLABORASI</span>
        <h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 leading-tight">
          WUJUDKAN IDE <br/><span class="italic text-accent font-normal">PROYEK ANDA</span>
        </h2>
        <p class="font-sans text-stone-500 text-xs md:text-sm leading-relaxed font-light">
          Mari diskusikan rencana perancangan arsitektur dan estimasi RAB pembangunan hunian idaman atau bangunan komersial Anda bersama tim ahli kami.
        </p>
        <a 
          href="/kalkulator-rab" 
          class="inline-flex items-center gap-3 font-sans text-xs uppercase tracking-widest text-stone-900 hover:text-accent font-medium transition-colors group"
        >
          HITUNG RAB ESTIMATOR
          <span class="text-accent transform group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

    </div>

    <!-- Fixed Bottom Status Bar (Desktop only) -->
    <div class="fixed bottom-0 left-0 right-0 z-20 px-[6vw] pb-8 pt-4 pointer-events-none hidden md:flex md:flex-row md:items-end md:justify-between gap-4">
      
      <!-- Big "WORKS" label on bottom-left (decorative) -->
      <div class="pointer-events-auto">
        <span aria-hidden="true" class="font-sans text-[10vw] md:text-[7vw] font-bold tracking-tighter leading-none text-stone-900/90 select-none uppercase block">
          WORKS
        </span>
      </div>

      <!-- Center Scroll Percentage Indicator -->
      <div class="font-sans text-[10px] uppercase tracking-[0.25em] text-stone-400 mb-2 md:mb-4 pointer-events-auto">
        SCROLL DOWN TO EXPLORE <span class="scroll-percentage font-mono text-stone-900 font-semibold ml-1.5">(00%)</span>
      </div>

    </div>

  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Daftarkan ScrollTrigger ke GSAP
  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector('.horizontal-scroll-container');
  const track = document.querySelector('.horizontal-track');
  const stuckIntro = document.querySelector('.stuck-intro');

  if (container && track) {
    const getScrollAmount = () => {
      // Selisih antara lebar track horizontal total dengan lebar layar viewport
      return track.scrollWidth - window.innerWidth;
    };

    // Gunakan gsap.matchMedia() untuk performa optimal & hanya jalankan di desktop (>= 768px)
    let mm = gsap.matchMedia();

    mm.add("(min-width: 768px)", () => {
      // Buat animasi horizontal slide yang dipicu oleh vertikal scroll
      const scrollTween = gsap.to(track, {
        x: () => -getScrollAmount(),
        ease: 'none',
        scrollTrigger: {
          trigger: container,
          pin: true,
          scrub: 1, // Menambahkan inersia scroll agar sangat mulus
          start: 'top top',
          end: () => `+=${getScrollAmount()}`,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            // Perbarui teks indikator persentase scroll
            const pctElement = document.querySelector('.scroll-percentage');
            if (pctElement) {
              const pct = Math.round(self.progress * 100);
              pctElement.textContent = `(${String(pct).padStart(2, '0')}%)`;
            }

            // Efek memudar dan parallax halus untuk stuck intro saat discroll
            if (stuckIntro) {
              const progressThreshold = 0.15; // Selesai memudar di 15% awal perjalanan scroll
              if (self.progress <= progressThreshold) {
                const opacity = 1 - (self.progress / progressThreshold);
                const xTranslate = -40 * (self.progress / progressThreshold); // Sedikit bergeser ke kiri
                gsap.set(stuckIntro, { 
                  opacity: opacity, 
                  x: xTranslate,
                  pointerEvents: opacity < 0.1 ? 'none' : 'auto'
                });
              } else {
                gsap.set(stuckIntro, { opacity: 0, x: -40 });
              }
            }
          }
        }
      });

      return () => {
        // Membersihkan tween dan ScrollTrigger saat media query tidak lagi cocok
        scrollTween.scrollTrigger?.kill();
        scrollTween.kill();
      };
    });

    // Event listener pembersihan transisi Astro (untuk pembersihan penuh saat pindah halaman)
    document.addEventListener('astro:before-preparation', () => {
      mm.revert();
    });
  }

  // Lazy load and autoplay/pause horizontal cover videos when they enter the viewport
  if ('IntersectionObserver' in window) {
    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          if (!video.src && video.dataset.src) {
            video.src = video.dataset.src;
            video.load();
          }
          video.play()
            .then(() => {
              video.style.opacity = '1';
            })
            .catch(() => {});
        } else {
          video.pause();
          video.style.opacity = '0';
        }
      });
    }, {
      root: null, // viewport
      threshold: 0.05 // play when 5% visible
    });

    const videos = document.querySelectorAll('.lazy-portfolio-video');
    videos.forEach((video) => {
      videoObserver.observe(video);
    });

    // Clean up observer on Astro navigation
    document.addEventListener('astro:before-preparation', () => {
      videoObserver.disconnect();
    }, { once: true });
  }
</script>

<style>
  /* Menghilangkan scrollbar default agar tampilan bersih */
  .horizontal-scroll-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .horizontal-scroll-container::-webkit-scrollbar {
    display: none;
  }
</style>
