---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const rawProjects = await reader.collections.projects.all();
const projects = rawProjects.map(p => ({
  slug: p.slug,
  ...p.entry
}));

// Variasi aspek rasio asimetris untuk estetika editorial premium (OH Architecture style)
const layouts = [
  { container: 'h-[50vh] md:h-[58vh] aspect-[3/4]', imgClass: 'aspect-[3/4]' },     // Tinggi Tegak (Vertikal)
  { container: 'h-[38vh] md:h-[45vh] aspect-[16/10]', imgClass: 'aspect-[16/10]' }, // Lebar Sedang (Horizontal)
  { container: 'h-[44vh] md:h-[52vh] aspect-[1/1]', imgClass: 'aspect-[1/1]' },     // Kotak (Square)
  { container: 'h-[32vh] md:h-[38vh] aspect-[4/3]', imgClass: 'aspect-[4/3]' }      // Kecil Lebar
];
---

<BaseLayout 
  title="Portofolio Kontraktor & Arsitektur — Creativa Studio"
  heroFullBleed={true}
  hideFooter={true}
>
  <!-- Main Horizontal Scroll Container -->
  <div class="horizontal-scroll-container w-full min-h-screen overflow-hidden bg-[#FAF9F6] relative flex items-center">
    
    <!-- Stuck Intro Section (Tetap berada di kiri layar) -->
    <div class="stuck-intro absolute left-[8vw] top-1/2 -translate-y-1/2 w-[280px] md:w-[400px] z-10 flex flex-col justify-center pr-8 space-y-6 pointer-events-none">
      <span class="font-sans text-[10px] font-semibold tracking-[0.25em] text-accent uppercase block">CREATIVA STUDIO</span>
      <h2 class="font-serif text-3xl md:text-5xl font-light text-stone-900 leading-tight">
        KURASI KARYA <br/><span class="italic text-accent font-normal">ARSITEKTUR & RAB</span>
      </h2>
      <p class="font-sans text-stone-500 text-xs md:text-sm leading-relaxed font-light">
        Kumpulan proyek pilihan pembangunan hunian mewah, gedung komersial, dan renovasi presisi tinggi yang memadukan kekuatan struktur dengan keindahan visual.
      </p>
    </div>
    
    <!-- Outer horizontal track that moves -->
    <div class="horizontal-track flex flex-row items-center gap-16 md:gap-24 px-[8vw] h-full select-none">
      
      <!-- Spacer untuk memberi ruang bagi Intro Section yang stuck di awal -->
      <div class="flex-shrink-0 w-[280px] md:w-[400px] mr-12 md:mr-16"></div>

      <!-- Projects Slides with asymmetric layout structure -->
      {projects.map((proj, idx) => {
        const layout = layouts[idx % layouts.length];
        
        return (
          <div class={`flex-shrink-0 flex flex-col justify-center project-item`}>
            <a href={`/portofolio/${proj.slug}`} class="group block cursor-pointer">
              
              <!-- Image element with premium transition styling -->
              <div class={`${layout.container} overflow-hidden bg-stone-100 relative`}>
                <img 
                  src={proj.coverImage} 
                  alt={proj.title}
                  class="w-full h-full object-cover filter brightness-[0.96] contrast-[1.02] sepia-[0.08] hover:sepia-0 hover:brightness-100 transition-all duration-1000 group-hover:scale-[1.03]"
                  loading="lazy"
                />
                <!-- Subtle overlay shade -->
                <div class="absolute inset-0 bg-stone-900/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
              </div>
              
              <!-- Label / Metadata below image -->
              <div class="mt-4 space-y-1">
                <h3 class="font-sans text-xs md:text-sm font-semibold tracking-widest text-stone-900 uppercase group-hover:text-accent transition-colors duration-300">
                  {proj.title}
                </h3>
                <p class="font-sans text-[10px] text-stone-500 uppercase tracking-[0.2em] font-light">
                  {proj.category} — {proj.location}
                </p>
              </div>

            </a>
          </div>
        );
      })}

      <!-- Final Slide: CTA to Contact -->
      <div class="flex-shrink-0 w-[300px] md:w-[450px] flex flex-col justify-center pl-8 space-y-6 pr-[8vw]">
        <span class="font-sans text-[10px] font-semibold tracking-[0.25em] text-accent uppercase block">KOLABORASI</span>
        <h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 leading-tight">
          WUJUDKAN IDE <br/><span class="italic text-accent font-normal">PROYEK ANDA</span>
        </h2>
        <p class="font-sans text-stone-500 text-xs md:text-sm leading-relaxed font-light">
          Mari diskusikan rencana perancangan arsitektur dan estimasi RAB pembangunan hunian idaman atau bangunan komersial Anda bersama tim ahli kami.
        </p>
        <a 
          href="/kalkulator-rab" 
          class="inline-flex items-center gap-3 font-sans text-xs uppercase tracking-widest text-stone-900 hover:text-accent font-medium transition-colors group"
        >
          HITUNG RAB ESTIMATOR
          <span class="text-accent transform group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

    </div>

    <!-- Fixed Bottom Status Bar (OH Architecture style) -->
    <div class="fixed bottom-0 left-0 right-0 z-20 px-[6vw] pb-8 pt-4 pointer-events-none flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      
      <!-- Big "WORKS" label on bottom-left -->
      <div class="pointer-events-auto">
        <h1 class="font-sans text-[10vw] md:text-[7vw] font-bold tracking-tighter leading-none text-stone-900/90 select-none uppercase">
          WORKS
        </h1>
      </div>

      <!-- Center Scroll Percentage Indicator -->
      <div class="font-sans text-[10px] uppercase tracking-[0.25em] text-stone-400 mb-2 md:mb-4 pointer-events-auto">
        SCROLL DOWN TO EXPLORE <span class="scroll-percentage font-mono text-stone-900 font-semibold ml-1.5">(00%)</span>
      </div>

    </div>

  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Daftarkan ScrollTrigger ke GSAP
  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector('.horizontal-scroll-container');
  const track = document.querySelector('.horizontal-track');
  const stuckIntro = document.querySelector('.stuck-intro');

  if (container && track) {
    const getScrollAmount = () => {
      // Selisih antara lebar track horizontal total dengan lebar layar viewport
      return track.scrollWidth - window.innerWidth;
    };

    // Buat animasi horizontal slide yang dipicu oleh vertikal scroll
    const scrollTween = gsap.to(track, {
      x: () => -getScrollAmount(),
      ease: 'none',
      scrollTrigger: {
        trigger: container,
        pin: true,
        scrub: 1, // Menambahkan inersia scroll agar sangat mulus
        start: 'top top',
        end: () => `+=${getScrollAmount()}`,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          // Perbarui teks indikator persentase scroll
          const pctElement = document.querySelector('.scroll-percentage');
          if (pctElement) {
            const pct = Math.round(self.progress * 100);
            pctElement.textContent = `(${String(pct).padStart(2, '0')}%)`;
          }

          // Efek memudar dan parallax halus untuk stuck intro saat discroll
          if (stuckIntro) {
            const progressThreshold = 0.15; // Selesai memudar di 15% awal perjalanan scroll
            if (self.progress <= progressThreshold) {
              const opacity = 1 - (self.progress / progressThreshold);
              const xTranslate = -40 * (self.progress / progressThreshold); // Sedikit bergeser ke kiri
              gsap.set(stuckIntro, { 
                opacity: opacity, 
                x: xTranslate,
                pointerEvents: opacity < 0.1 ? 'none' : 'auto'
              });
            } else {
              gsap.set(stuckIntro, { opacity: 0, x: -40 });
            }
          }
        }
      }
    });

    // Event listener pembersihan transisi Astro
    document.addEventListener('astro:before-preparation', () => {
      scrollTween.scrollTrigger?.kill();
      scrollTween.kill();
    });
  }
</script>

<style>
  /* Menghilangkan scrollbar default agar tampilan bersih */
  .horizontal-scroll-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .horizontal-scroll-container::-webkit-scrollbar {
    display: none;
  }
</style>
